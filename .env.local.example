NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Side ad rails are hidden by default. Set to "true" to show placeholder
# rails (the AdRail component lives in components/AdRail.tsx).
NEXT_PUBLIC_AD_SLOTS_ENABLED=false

# Google AdSense — once your account is approved, set these to activate ads.
# The AdSense script only loads if a client ID is set AND the visitor has
# accepted cookies via the consent banner. See ADSENSE_SETUP.md.
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT_LEFT_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_LEFT_MID=
NEXT_PUBLIC_ADSENSE_SLOT_RIGHT_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_RIGHT_MID=
